---
import Layout from "../layouts/layout.astro";
---

<Layout title="404, not found" description="page not found">
	<main id="main-content" class="page lowercaseable" style="text-align:center">
		<h1
			class="display"
			style="font-size:96px;margin-top:60px;color:var(--accent)"
		>
			404
		</h1>
		<p class="blurb" style="margin: 0 auto 28px">page not found.</p>
		<a href="/" class="link-arrow" aria-label="return to the homepage">
			← back home
		</a>
	</main>
</Layout>
