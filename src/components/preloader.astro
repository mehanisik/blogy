---

---

<script is:inline>
  if (sessionStorage.getItem("preloader-shown")) {
    document.documentElement.classList.add("preloader-seen");
  }
</script>
<div class="preloader" id="preloader">
  <div class="preloader-content">
    <div class="preloader-text">
      <span class="preloader-char">M</span>
      <span class="preloader-char">E</span>
      <span class="preloader-char">H</span>
      <span class="preloader-char">A</span>
      <span class="preloader-char">N</span>
      <span class="preloader-char">I</span>
      <span class="preloader-char">S</span>
      <span class="preloader-char">I</span>
      <span class="preloader-char">K</span>
    </div>
    <div class="preloader-line"></div>
  </div>
</div>

<style>
  .preloader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--bg-color);
    pointer-events: none;
  }

  .preloader-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .preloader-text {
    display: flex;
    overflow: hidden;
  }

  .preloader-char {
    display: inline-block;
    font-size: clamp(2rem, 8vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--accent-color);
    transform: translateY(100%);
    opacity: 0;
  }

  .preloader-line {
    width: 0;
    height: 1px;
    background-color: var(--border-color-strong);
  }

  @media (prefers-reduced-motion: reduce) {
    .preloader {
      display: none;
    }
  }

  :global(html.preloader-seen) .preloader {
    display: none;
  }
</style>

<script>
  import gsap from "gsap";

  const PRELOADER_KEY = "preloader-shown";
  const preloader = document.getElementById("preloader");
  const chars = document.querySelectorAll(".preloader-char");
  const line = document.querySelector(".preloader-line");

  const skipPreloader = () => {
    if (preloader) preloader.remove();
    window.dispatchEvent(new CustomEvent("preloader-done"));
  };

  if (!preloader || chars.length === 0 || !line) {
    window.dispatchEvent(new CustomEvent("preloader-done"));
  } else if (sessionStorage.getItem(PRELOADER_KEY)) {
    skipPreloader();
  } else {
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    if (prefersReducedMotion) {
      sessionStorage.setItem(PRELOADER_KEY, "true");
      skipPreloader();
    } else {
      const tl = gsap.timeline({
        onComplete: () => {
          sessionStorage.setItem(PRELOADER_KEY, "true");
          window.dispatchEvent(new CustomEvent("preloader-done"));
        },
      });

      tl.to(chars, {
        y: "0%",
        opacity: 1,
        duration: 0.8,
        stagger: 0.05,
        ease: "expo.out",
      })
        .to(
          line,
          {
            width: "120px",
            duration: 0.6,
            ease: "power2.inOut",
          },
          "-=0.4"
        )
        .to(
          {},
          {
            duration: 0.3,
          }
        )
        .to(line, {
          width: 0,
          duration: 0.4,
          ease: "power2.in",
        })
        .to(
          chars,
          {
            y: "-100%",
            opacity: 0,
            duration: 0.5,
            stagger: 0.03,
            ease: "expo.in",
          },
          "-=0.2"
        )
        .to(preloader, {
          clipPath: "polygon(0 0, 100% 0, 100% 0, 0 0)",
          duration: 0.8,
          ease: "expo.inOut",
          onComplete: () => {
            preloader.remove();
          },
        });
    }
  }
</script>
