---
import type { Hero } from "../lib/api";
import AnimatedText from "./animated-text.astro";
import HeroAnimation from "./hero-animation.astro";

interface Props {
  hero?: Hero;
}

const { hero } = Astro.props;

const tagline =
  hero?.tagline || "Building digital experiences with code and creativity.";
---

<section
    class="relative w-full min-h-screen flex items-center justify-center overflow-hidden"
>
    <HeroAnimation />

    <div
        class="relative z-10 container mx-auto px-6 pt-20 flex flex-col items-center justify-center text-center h-full"
    >
        <div class="max-w-5xl">
            <h1
                class="text-6xl md:text-9xl font-bold tracking-tighter mb-12 leading-none"
            >
                <AnimatedText
                    text="MEHANISIK"
                    tag="span"
                    class="text-(--accent-color)"
                />
            </h1>

            <p
                class="text-xl md:text-2xl text-(--text-secondary) max-w-2xl mx-auto leading-relaxed"
            >
                <AnimatedText text={tagline} delay={300} />
            </p>
        </div>
    </div>
</section>

