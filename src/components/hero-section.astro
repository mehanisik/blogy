---
import { hero, navLinks } from "../data/portfolio";

const name = hero.name.toLowerCase();
const role = hero.role.toLowerCase();
const highlight = hero.highlight;
const parts = hero.summary.split(/(\{\{role\}\}|\{\{hl\}\})/);

const email = hero.contact.email;
const github = hero.contact.github;
const linkedin = hero.contact.linkedin;
---

<header class="hero lowercaseable">
	<div class="hero-top">
		<a href="/" class="avatar" aria-label="home">
			<svg viewBox="0 0 48 48" width="36" height="36" aria-hidden="true">
				<rect width="48" height="48" rx="10" fill="var(--ink)" />
				<circle cx="24" cy="19" r="7" fill="var(--bg)" opacity="0.92" />
				<path
					d="M8 44 C 10 32, 38 32, 40 44 Z"
					fill="var(--bg)"
					opacity="0.92"
				/>
				<circle cx="36" cy="12" r="3" fill="var(--accent)" />
			</svg>
		</a>
		<nav class="top-nav" aria-label="primary">
			{navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
		</nav>
	</div>

	<h1 class="display">{name}</h1>

	<p class="blurb">
		{
			parts.map((p: string) => {
				if (p === "{{role}}") return <span class="role-link">{role}</span>;
				if (p === "{{hl}}") return <span class="hl">{highlight}</span>;
				return <>{p}</>;
			})
		}
	</p>

	<div class="socials" role="list">
		<a href={`mailto:${email}`} aria-label="email" title="email">
			<svg
				viewBox="0 0 24 24"
				width="16"
				height="16"
				fill="none"
				stroke="currentColor"
				stroke-width="1.6"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<rect x="3" y="5" width="18" height="14" rx="2"></rect>
				<path d="M3 7l9 7 9-7"></path>
			</svg>
		</a>
		<a
			href={github}
			aria-label="github"
			title="github"
			target="_blank"
			rel="noopener noreferrer"
		>
			<svg
				viewBox="0 0 24 24"
				width="16"
				height="16"
				fill="none"
				stroke="currentColor"
				stroke-width="1.6"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<path
					d="M9 19c-4 1.5-4-2-6-2.5m12 4v-3.5a3.4 3.4 0 0 0-.9-2.6c3-.3 6-1.5 6-6.5a5 5 0 0 0-1.4-3.5 4.6 4.6 0 0 0-.1-3.5s-1.1-.3-3.6 1.3a12.3 12.3 0 0 0-6 0C6.5 1.3 5.4 1.6 5.4 1.6a4.6 4.6 0 0 0-.1 3.5A5 5 0 0 0 3.9 8.6c0 5 3 6.2 6 6.5a3.4 3.4 0 0 0-.9 2.5V21"
				></path>
			</svg>
		</a>
		<a
			href={linkedin}
			aria-label="linkedin"
			title="linkedin"
			target="_blank"
			rel="noopener noreferrer"
		>
			<svg
				viewBox="0 0 24 24"
				width="16"
				height="16"
				fill="none"
				stroke="currentColor"
				stroke-width="1.6"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<rect x="3" y="3" width="18" height="18" rx="2"></rect>
				<path d="M8 10v7M8 7v.01M12 17v-4a2 2 0 0 1 4 0v4M12 10v7"></path>
			</svg>
		</a>
		<a href="/rss.xml" aria-label="rss" title="rss">
			<svg
				viewBox="0 0 24 24"
				width="16"
				height="16"
				fill="none"
				stroke="currentColor"
				stroke-width="1.6"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<path d="M4 11a9 9 0 0 1 9 9M4 4a16 16 0 0 1 16 16"></path>
				<circle cx="5" cy="19" r="1" fill="currentColor"></circle>
			</svg>
		</a>
	</div>
</header>
