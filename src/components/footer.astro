---
import { hero } from "../data/portfolio";

const year = new Date().getFullYear();
const email = hero.contact.email;
const linkedin = hero.contact.linkedin;
const github = hero.contact.github;
const location = hero.location.toLowerCase();
---

<footer class="site-footer fade-in lowercaseable" id="contact">
	<h2>let's work together</h2>
	<div class="contact-row">
		<a href={`mailto:${email}`} class="contact-link" aria-label="email">
			<svg
				viewBox="0 0 24 24"
				width="16"
				height="16"
				fill="none"
				stroke="currentColor"
				stroke-width="1.6"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<rect x="3" y="5" width="18" height="14" rx="2"></rect>
				<path d="M3 7l9 7 9-7"></path>
			</svg>
			email me
		</a>
		<span class="dot">·</span>
		<a
			href={linkedin}
			class="contact-link"
			target="_blank"
			rel="noopener noreferrer"
			aria-label="linkedin (opens in new tab)"
		>
			<svg
				viewBox="0 0 24 24"
				width="16"
				height="16"
				fill="none"
				stroke="currentColor"
				stroke-width="1.6"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<rect x="3" y="3" width="18" height="18" rx="2"></rect>
				<path d="M8 10v7M8 7v.01M12 17v-4a2 2 0 0 1 4 0v4M12 10v7"></path>
			</svg>
			linkedin
		</a>
		<span class="dot">·</span>
		<a
			href={github}
			class="contact-link"
			target="_blank"
			rel="noopener noreferrer"
			aria-label="github (opens in new tab)"
		>
			<svg
				viewBox="0 0 24 24"
				width="16"
				height="16"
				fill="none"
				stroke="currentColor"
				stroke-width="1.6"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<path
					d="M9 19c-4 1.5-4-2-6-2.5m12 4v-3.5a3.4 3.4 0 0 0-.9-2.6c3-.3 6-1.5 6-6.5a5 5 0 0 0-1.4-3.5 4.6 4.6 0 0 0-.1-3.5s-1.1-.3-3.6 1.3a12.3 12.3 0 0 0-6 0C6.5 1.3 5.4 1.6 5.4 1.6a4.6 4.6 0 0 0-.1 3.5A5 5 0 0 0 3.9 8.6c0 5 3 6.2 6 6.5a3.4 3.4 0 0 0-.9 2.5V21"
				></path>
			</svg>
			github
		</a>
		<span class="dot">·</span>
		<a
			href="/rss.xml"
			class="contact-link"
			aria-label="rss feed"
		>
			rss
		</a>
	</div>
	<p class="colophon">
		{location} · built with astro · <span class="mono">© {year}</span>
	</p>
</footer>
