---
export interface WritingItem {
  title: string;
  date: Date | string;
  type: string;
  slug?: string | null;
  url?: string | null;
  metadata?: unknown;
}
interface WritingMetadata {
  doi?: string;
}

interface Props {
  writings: WritingItem[];
}
const { writings } = Astro.props;

const getLink = (item: WritingItem) => {
  if ((item.type === "blog" || item.type === "paper") && item.slug)
    return `/blog/${item.slug}`;
  const meta = item.metadata as WritingMetadata | undefined;
  return item.url || meta?.doi || "#";
};

const isExternal = (item: WritingItem) =>
  item.type !== "blog" && item.type !== "paper";

const formatDate = (d: Date | string) =>
  new Date(d)
    .toLocaleDateString("en-US", {
      month: "short",
      day: "numeric",
      year: "numeric",
    })
    .toLowerCase();
---

{
	writings.length === 0 ? (
		<p class="mono" style="color:var(--ink-mute);font-size:13px">no writings yet.</p>
	) : (
		<ul class="notes lowercaseable">
			{writings.map((w, i) => (
				<li style={`--i:${i}`}>
					<a
						href={getLink(w)}
						target={isExternal(w) ? "_blank" : undefined}
						rel={isExternal(w) ? "noopener noreferrer" : undefined}
					>
						<span class="note-title">{w.title}</span>
						<span class="note-dots" aria-hidden="true" />
						<span class="note-date">{formatDate(w.date)}</span>
					</a>
				</li>
			))}
		</ul>
	)
}
