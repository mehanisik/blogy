---
import {
  GithubIcon,
  Linkedin01Icon,
  Mail01Icon,
  NewTwitterIcon,
} from "@hugeicons/core-free-icons";
import { HugeiconsIcon } from "@hugeicons/react";
import { siteConfig } from "../config";
import type { Hero } from "../lib/api";

interface Props {
  hero?: Hero;
}

const { hero } = Astro.props;
---

<section id="contact" class="w-full border-t border-[var(--border-color)] pt-12">
	<div class="grid grid-cols-1 md:grid-cols-12 gap-12">
		<div class="md:col-span-3">
			<h2
				class="text-xs font-mono text-[var(--accent-color)] uppercase tracking-widest"
			>
				About Me
			</h2>
		</div>
		<div class="md:col-span-9">
			<p class="text-2xl md:text-4xl leading-tight font-medium mb-12">
				{
					hero?.summary ||
						"I am a frontend developer passionate about building digital products that matter. With a focus on clean design and robust engineering, I create experiences that are both beautiful and functional."
				}
			</p>

			<div class="grid grid-cols-1 sm:grid-cols-2 gap-12 text-sm">
				<div>
					<h3
						class="font-mono text-[var(--text-tertiary)] uppercase tracking-widest mb-6 text-xs"
					>
						Contact
					</h3>
					<div class="flex flex-col gap-4">
						{
							hero?.contact?.email && (
								<a
									href={`mailto:${hero.contact.email}`}
									class="flex items-center gap-2 hover:text-[var(--accent-color)] transition-colors group"
									aria-label={`Send email to ${hero.contact.email}`}
								>
									<HugeiconsIcon
										icon={Mail01Icon}
										aria-hidden="true"
										className="w-4 h-4 text-[var(--text-tertiary)] group-hover:text-[var(--accent-color)] transition-colors"
									/>
									{hero.contact.email}
								</a>
							)
						}
					</div>
				</div>
				<div>
					<h3
						class="font-mono text-[var(--text-tertiary)] uppercase tracking-widest mb-6 text-xs"
					>
						Socials
					</h3>
					<div class="flex flex-col gap-4">
						{
							hero?.contact?.linkedin && (
								<a
									href={hero.contact.linkedin}
									target="_blank"
									rel="noopener noreferrer"
									class="flex items-center gap-2 hover:text-[var(--accent-color)] transition-colors group"
									aria-label="LinkedIn (opens in new tab)"
								>
									<HugeiconsIcon
										icon={Linkedin01Icon}
										aria-hidden="true"
										className="w-4 h-4 text-[var(--text-tertiary)] group-hover:text-[var(--accent-color)] transition-colors"
									/>
									LinkedIn
								</a>
							)
						}
						{
							hero?.contact?.github && (
								<a
									href={hero.contact.github}
									target="_blank"
									rel="noopener noreferrer"
									class="flex items-center gap-2 hover:text-[var(--accent-color)] transition-colors group"
									aria-label="GitHub (opens in new tab)"
								>
									<HugeiconsIcon
										icon={GithubIcon}
										aria-hidden="true"
										className="w-4 h-4 text-[var(--text-tertiary)] group-hover:text-[var(--accent-color)] transition-colors"
									/>
									GitHub
								</a>
							)
						}
						<a
							href={siteConfig.links.x}
							target="_blank"
							rel="noopener noreferrer"
							class="flex items-center gap-2 hover:text-[var(--accent-color)] transition-colors group"
							aria-label="Twitter/X (opens in new tab)"
						>
							<HugeiconsIcon
								icon={NewTwitterIcon}
								aria-hidden="true"
								className="w-4 h-4 text-[var(--text-tertiary)] group-hover:text-[var(--accent-color)] transition-colors"
							/>
							Twitter
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
